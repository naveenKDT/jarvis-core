# ── Server ──────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
APP_RELOAD=true

# ── Ollama / LLM ────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TIMEOUT=300

# ── Generated output ────────────────────────────────────
GENERATED_SITES_DIR=generated_sites

# ── Logging ─────────────────────────────────────────────
LOG_LEVEL=INFO
