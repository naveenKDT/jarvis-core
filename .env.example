# ── Security ─────────────────────────────────────────────
JARVIS_API_KEY=change-me-to-a-random-secret
JARVIS_CORS_ORIGINS=http://localhost:3000

# ── Server ──────────────────────────────────────────────
APP_HOST=127.0.0.1
APP_PORT=8000
APP_RELOAD=false

# ── Ollama / LLM ────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TIMEOUT=300

# ── Generated output ────────────────────────────────────
GENERATED_SITES_DIR=generated_sites

# ── Logging ─────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Sony Bravia TV ──────────────────────────────────────
SONY_TV_IP=192.168.1.100
SONY_TV_PSK=0000

# ── Voice ───────────────────────────────────────────────
VOICE_ENABLED=false
WAKE_WORD=jarvis
